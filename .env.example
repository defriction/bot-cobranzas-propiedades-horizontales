# GROQ API Key (Modelo Llama3 para IA)
GROQ_API_KEY=groq_default_key_aqui

# ID del Google Sheet (puedes sacarlo de la URL de tu documento)
SHEET_ID=1A2B3C4D5E6F7G8H9I0J_default_id_aqui

# URLs y Tokens para la Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_TOKEN=evolution_default_token_aqui
EVOLUTION_INSTANCE_NAME=EvolutionInstance_aqui

# Token de Seguridad para Proteger los Endpoints (Tanto en .env como en GitHub Secrets)
API_SECRET_KEY=mi_super_clave_123

# Configuracion SMTP para envio de correos (ejemplo: Brevo)
SMTP_ENABLED=false
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=tu_login_smtp
SMTP_PASSWORD=tu_clave_smtp
SMTP_FROM_EMAIL=correo_verificado@tudominio.com
SMTP_FROM_NAME=Administracion Arboreto Guayacan
SMTP_REPLY_TO=administracion@tudominio.com
SMTP_LIST_UNSUBSCRIBE_EMAIL=soporte@tudominio.com

# Limite diario y archivos de control de cola de correos
APP_TIMEZONE=America/Bogota
EMAIL_DAILY_LIMIT=150
EMAIL_QUEUE_FILE=data/email_queue.json
EMAIL_QUOTA_FILE=data/email_quota_state.json
